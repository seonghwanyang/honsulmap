# Honsulmap migration worker — env template
# Copy to .env (or set in the Render dashboard) and fill in values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# Worker tunables
BATCH_SIZE=15
WORKERS=8

# Optional per-spot fetch hard ceiling (seconds). Workers exit if exceeded.
SPOT_TIMEOUT_SEC=120
